# =============================================================================
# APPLICATION
# =============================================================================
APP_TITLE=URL Shortener
APP_DESCRIPTION=–Т—Л—Б–Њ–Ї–Њ–њ—А–Њ–Є–Ј–≤–Њ–і–Є—В–µ–ї—М–љ—Л–є —Б–µ—А–≤–Є—Б —Б–Њ–Ї—А–∞—Й–µ–љ–Є—П URL
APP_VERSION=1.0.0
APP_DEBUG=False
APP_ENVIRONMENT=production
APP_WORKERS=4
APP_MAX_REQUESTS=1000
APP_MAX_REQUESTS_JITTER=100
APP_BASE_URL=https://your-domain.com
APP_SHORT_CODE_LENGTH=6
APP_MAX_ATTEMPTS=3
APP_PORT=8000

# =============================================================================
# DATABASE (PostgreSQL)
# =============================================================================
POSTGRES_DB=shortener
POSTGRES_USER=shortener
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

DATABASE_URL=postgresql+asyncpg://shortener:change_me_in_production@db:5432/shortener
DATABASE_TEST_URL=sqlite+aiosqlite:///:memory:
DATABASE_POOL_TIMEOUT=30
DATABASE_POOL_RECYCLE=1800
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30
DATABASE_POOL_PING=True
DATABASE_ECHO_SQL=False

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=change_me_in_production
REDIS_PORT=6379

REDIS_URL=redis://:change_me_in_production@redis:6379/0
REDIS_SOCKET_CONNECT_TIMEOUT=5
REDIS_SOCKET_TIMEOUT=5
REDIS_RETRY_ON_TIMEOUT=True
REDIS_MAX_CONNECTIONS=10
REDIS_REDIRECT_CACHE_TTL=3600
REDIS_CLICK_CACHE_TTL=300
REDIS_RATE_LIMIT_TTL=60

# =============================================================================
# ARQ WORKER
# =============================================================================
WORKER_REDIS_DSN=redis://:change_me_in_production@redis:6379/1
WORKER_QUEUE_NAME=click_tasks
WORKER_MAX_JOBS=10
WORKER_JOB_TIMEOUT=30
WORKER_MAX_TRIES=3

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json